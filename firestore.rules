rules_version = '2';

// Biotech Grading — Firestore security rules
// Data lives under: artifacts/{appId}/public/data/{groups|reviews}/{docId}
// Any signed-in user (anonymous auth) may read/write within the app namespace.
// This matches the app design (students submit peer reviews, teacher reads them).
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
